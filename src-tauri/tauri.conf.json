{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Microsoft Email Manager Desktop",
  "version": "0.1.0",
  "identifier": "com.maishan.mem.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Microsoft Email Manager Desktop",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "deb", "appimage", "rpm"],
    "publisher": "Maishan Inc.",
    "copyright": "© 2026 Maishan Inc.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "本地化 Microsoft 邮箱账户与邮件管理",
    "longDescription": "数据全本地存储、凭据加密、支持导出的 Microsoft 邮箱管理桌面端。",
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    }
  }
}
